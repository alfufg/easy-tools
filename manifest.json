{
    "name": "Easy Tools",
    "short_name": "EasyTools",
    "version": "1.0.0",
    "manifest_version": 3,
    "description": "多工具合一的浏览器扩展，提供小红书评论采集、抖音评论采集、视频下载、录屏、SEO排位查询等实用功能",
    "author": "Ben",
    "homepage_url": "https://github.com/ben/easy-tools",
    "permissions": [
      "tabs",
      "sidePanel",
      "scripting",
      "activeTab",
      "webNavigation",
      "notifications",
      "downloads",
      "cookies",
      "storage"
    ],
    "host_permissions": [
      "<all_urls>",
      "*://*.xiaohongshu.com/*",
      "*://*.douyin.com/*"
    ],
    "side_panel": {
      "default_path": "./dist/src/popup/index.html"
    },
    "action": {
        "default_title": "Ben's tools"
    },
    "background": {
      "service_worker": "./src/background.js",
      "type": "module"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": [
          "./src/libs/jquery/jquery-3.7.1.min.js"
        ],
        "run_at": "document_start"
      }
    ],
    "web_accessible_resources": [
      {
        "resources": [
          "src/*"
        ],
        "matches": ["<all_urls>"]
      }
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
    },
    "icons": {
      "16": "./src/assets/icons/icon16.png",
      "48": "./src/assets/icons/icon48.png",
      "128": "./src/assets/icons/icon128.png"
    }
  }
