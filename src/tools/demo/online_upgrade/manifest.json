{
  "manifest_version": 3,
  "name": "企业内部自动更新插件",
  "version": "1.0.0",
  "description": "支持自动更新的企业内部Chrome插件",
  "permissions": [
      "activeTab",
      "notifications",
      "scripting",
      "downloads",
      "alarms",
      "management"
  ],
  "host_permissions": [
      "*://*/*"
  ],
  "optional_permissions": [
      "downloads.open"
  ],
  "background": {
      "service_worker": "background.js",
      "type": "module"
  },
  "action": {
      "default_popup": "popup.html",
      "default_icon": {
          "16": "easytools.png",
          "48": "easytools.png",
          "128": "easytools.png"
      }
  },
  "update_url": "https://tools.toutiaoeasy.cn/extension/easytools/update.xml"
}
  